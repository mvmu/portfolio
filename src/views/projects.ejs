<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects</title>
</head>
<body>

    <h1>Projects</h1>
    <ul>
        <% if(payload.length > 0){ %>
            <% payload.forEach(({id, coverUrl, projectDescription, introduction, projectType, projectTitle}) => { %>
                <li><%= projectTitle %>, projectId: <%= id %>, projectType: <%= projectType %></li>
            <% }) %>
        <% }else{ %>
            <li>No project found</li>
        <% } %>
    </ul>
</body>
</html>